        "field": "value",
        "unit": "",
        "fixedTags": "{\"org\":\"ACME\",\"location\":\"Plant1\"}",
        "schema": "industrial",
        "x": 640,
        "y": 280,
        "wires": [["debug1"]]
    },
    {
        "id": "payload_override",
