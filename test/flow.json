[
    {
        "id": "inject_mqtt_full",
        "type": "inject",
        "name": "MQTT: full industrial mapping (naked)",
        "props": [
            { "p": "payload" },
            { "p": "topic" }
        ],
        "payload": "42.5",
        "payloadType": "num",
        "topic": "ACME/Plant1/Hall/Inverter1/power/active",
        "x": 240,
        "y": 80,
        "wires": [["mqtt_naked"]]
    },
    {
        "id": "inject_mqtt_json",
        "type": "inject",
        "name": "MQTT: JSON payload (fields from keys)",
        "props": [
            { "p": "payload" },
            { "p": "topic" }
        ],
        "payload": "{\"temperature\":21.5,\"humidity\":55,\"active\":true,\"note\":\"ok\"}",
        "payloadType": "json",
        "topic": "Home/Prague/Flat/Thermo1/env",
        "x": 240,
        "y": 140,
        "wires": [["mqtt_json"]]
    },
    {
        "id": "inject_mqtt_ignore",
        "type": "inject",
        "name": "MQTT: ignore topic (tags/meas/field from msg)",
        "props": [
            { "p": "payload" },
            { "p": "measurement" },
            { "p": "field" },
            { "p": "tags" }
        ],
        "payload": "77",
        "payloadType": "num",
        "measurement": "status",
        "field": "code",
        "tags": "{\"org\":\"ACME\",\"device\":\"Pump1\"}",
        "x": 240,
        "y": 200,
        "wires": [["mqtt_ignore"]]
    },
    {
        "id": "inject_payload_naked",
        "type": "inject",
        "name": "Payload: naked, tags from node",
        "props": [
            { "p": "payload" }
        ],
        "payload": "23.5",
        "payloadType": "num",
        "x": 240,
        "y": 280,
        "wires": [["payload_naked"]]
    },
    {
        "id": "inject_payload_override",
        "type": "inject",
        "name": "Payload: unit + timestamp override",
        "props": [
            { "p": "payload" },
            { "p": "unit" },
            { "p": "timestamp" }
        ],
        "payload": "100",
        "payloadType": "num",
        "unit": "kWh",
        "timestamp": "2025-05-19T10:00:00Z",
        "x": 240,
        "y": 340,
        "wires": [["payload_override"]]
    },
    {
        "id": "mqtt_naked",
        "type": "mqtt-to-timescaledb",
