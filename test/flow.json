        "server": "config1",
        "topicMapping": "org/location/building/device/measurement/field",
        "ignoreTopic": false,
        "payloadType": "naked",
        "unit": "",
        "fixedTags": "{}",
        "schema": "industrial",
        "x": 640,
        "y": 80,
        "wires": [["debug1"]]
    },
    {
        "id": "mqtt_json",
        "type": "mqtt-to-timescaledb",
        "name": "MQTT (home, JSON payload)",
        "server": "config1",
        "topicMapping": "name/location/building/device/measurement",
        "ignoreTopic": false,
        "payloadType": "json",
        "unit": "",
        "fixedTags": "{}",
        "schema": "home",
        "x": 640,
        "y": 140,
        "wires": [["debug1"]]
    },
    {
        "id": "mqtt_ignore",
        "type": "mqtt-to-timescaledb",
